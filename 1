<style>
  :root {
    --black: #0a0a0a;
    --dark: #111318;
    --card: #16191f;
    --border: #1e2229;
    --accent: #ff4d00;
    --accent2: #ffaa00;
    --text: #e8eaf0;
    --muted: #7a7f8e;
    --green: #00e676;
    --blue: #448aff;
  }

- { margin: 0; padding: 0; box-sizing: border-box; }

html, body {
width: 100%;
height: 100%;
overflow-x: hidden;
}

body {
background: var(–black);
color: var(–text);
font-family: ‘Barlow’, sans-serif;
min-height: 100vh;
overflow-x: hidden;
}

/* HERO */
.hero {
position: relative;
padding: 60px 40px 50px;
overflow: hidden;
border-bottom: 1px solid var(–border);
}
.hero::before {
content: ‘’;
position: absolute;
top: -60px; right: -80px;
width: 500px; height: 500px;
background: radial-gradient(circle, rgba(255,77,0,0.18) 0%, transparent 70%);
pointer-events: none;
}
.hero-badge {
display: inline-block;
background: var(–accent);
color: #fff;
font-family: ‘Barlow Condensed’, sans-serif;
font-size: 11px;
font-weight: 900;
letter-spacing: 3px;
text-transform: uppercase;
padding: 5px 14px;
border-radius: 2px;
margin-bottom: 18px;
}
.hero h1 {
font-family: ‘Bebas Neue’, sans-serif;
font-size: clamp(52px, 10vw, 100px);
line-height: 0.9;
letter-spacing: 2px;
color: #fff;
}
.hero h1 span { color: var(–accent); }
.hero-sub {
margin-top: 18px;
font-size: 15px;
color: var(–muted);
font-weight: 300;
letter-spacing: 0.5px;
max-width: 480px;
line-height: 1.6;
}
.hero-stats {
display: flex;
gap: 30px;
margin-top: 32px;
flex-wrap: wrap;
}
.stat {
display: flex;
flex-direction: column;
gap: 4px;
}
.stat-val {
font-family: ‘Bebas Neue’, sans-serif;
font-size: 36px;
color: var(–accent);
line-height: 1;
}
.stat-lbl {
font-size: 11px;
color: var(–muted);
letter-spacing: 2px;
text-transform: uppercase;
}

/* LEGEND */
.legend {
display: flex;
gap: 20px;
padding: 20px 40px;
background: var(–dark);
border-bottom: 1px solid var(–border);
flex-wrap: wrap;
}
.legend-item {
display: flex;
align-items: center;
gap: 8px;
font-size: 12px;
color: var(–muted);
letter-spacing: 1px;
text-transform: uppercase;
}
.dot { width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0; }

/* MAIN */
.container { max-width: 960px; margin: 0 auto; padding: 50px 20px; }

.semaine { margin-bottom: 60px; }
.semaine-header {
display: flex;
align-items: baseline;
gap: 16px;
margin-bottom: 20px;
padding-bottom: 12px;
border-bottom: 1px solid var(–border);
flex-wrap: wrap;
}
.semaine-num { font-family: ‘Bebas Neue’, sans-serif; font-size: 48px; color: var(–accent); line-height: 1; }
.semaine-title { font-family: ‘Barlow Condensed’, sans-serif; font-size: 22px; font-weight: 700; text-transform: uppercase; letter-spacing: 2px; color: #fff; }
.semaine-dates { font-size: 12px; color: var(–muted); margin-left: auto; letter-spacing: 1px; }

.days-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 14px; }

.day-card { background: var(–card); border: 1px solid var(–border); border-radius: 8px; overflow: hidden; transition: transform 0.2s, border-color 0.2s; }
.day-card:hover { transform: translateY(-3px); border-color: #2a2d36; }
.day-card.rest { border-style: dashed; opacity: 0.55; }

.day-header { display: flex; align-items: center; justify-content: space-between; padding: 12px 16px; border-bottom: 1px solid var(–border); }
.day-name { font-family: ‘Barlow Condensed’, sans-serif; font-size: 13px; font-weight: 700; letter-spacing: 3px; text-transform: uppercase; color: var(–muted); }
.day-date { font-family: ‘Bebas Neue’, sans-serif; font-size: 22px; color: #fff; line-height: 1; }
.day-tag { font-size: 10px; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; padding: 3px 10px; border-radius: 20px; }
.tag-push { background: rgba(255,77,0,0.15); color: var(–accent); }
.tag-pull { background: rgba(68,138,255,0.15); color: var(–blue); }
.tag-legs { background: rgba(0,230,118,0.12); color: var(–green); }
.tag-cardio { background: rgba(255,170,0,0.15); color: var(–accent2); }
.tag-full { background: rgba(200,100,255,0.15); color: #c87dff; }
.tag-rest { background: rgba(122,127,142,0.12); color: var(–muted); }

.day-body { padding: 14px 16px; }
.session-title { font-family: ‘Barlow Condensed’, sans-serif; font-size: 17px; font-weight: 700; color: #fff; letter-spacing: 1px; text-transform: uppercase; margin-bottom: 12px; }

.exo-list { list-style: none; display: flex; flex-direction: column; gap: 8px; }
.exo-item {
display: flex;
flex-direction: column;
gap: 2px;
padding: 8px 10px;
background: rgba(255,255,255,0.03);
border-left: 2px solid var(–border);
border-radius: 0 4px 4px 0;
cursor: pointer;
transition: border-color 0.2s, background 0.2s, transform 0.15s;
position: relative;
}
.exo-item:hover { border-left-color: var(–accent); background: rgba(255,77,0,0.07); transform: translateX(2px); }
.exo-item::after {
content: ‘ℹ’;
position: absolute;
right: 8px; top: 50%; transform: translateY(-50%);
font-size: 13px; color: var(–accent);
opacity: 0; transition: opacity 0.2s;
}
.exo-item:hover::after { opacity: 1; }
.exo-name { font-size: 13px; font-weight: 600; color: var(–text); }
.exo-detail { font-size: 11px; color: var(–muted); font-weight: 300; letter-spacing: 0.5px; }
.rest-text { font-size: 13px; color: var(–muted); font-style: italic; padding: 8px 0; }

/* ====== MODAL ====== */
.modal-overlay {
display: none;
position: fixed; inset: 0;
background: rgba(0,0,0,0.85);
backdrop-filter: blur(6px);
z-index: 1000;
align-items: center;
justify-content: center;
padding: 20px;
}
.modal-overlay.active { display: flex; }

.modal {
background: var(–dark);
border: 1px solid var(–border);
border-radius: 12px;
width: 100%;
max-width: 560px;
max-height: 90vh;
overflow-y: auto;
position: relative;
animation: modalIn 0.3s cubic-bezier(0.34,1.56,0.64,1);
}
@keyframes modalIn {
from { opacity: 0; transform: scale(0.88) translateY(20px); }
to { opacity: 1; transform: scale(1) translateY(0); }
}

.modal-close {
position: sticky; top: 0;
display: flex; justify-content: flex-end;
padding: 14px 16px 0;
background: var(–dark);
z-index: 2;
}
.close-btn {
background: rgba(255,255,255,0.07);
border: none; color: var(–muted);
width: 32px; height: 32px;
border-radius: 50%; cursor: pointer;
font-size: 18px; line-height: 32px; text-align: center;
transition: background 0.2s, color 0.2s;
}
.close-btn:hover { background: var(–accent); color: #fff; }

.modal-img-wrap {
margin: 0 16px 0;
border-radius: 8px;
overflow: hidden;
background: #0d0f14;
min-height: 200px;
display: flex; align-items: center; justify-content: center;
border: 1px solid var(–border);
position: relative;
}
.modal-img-wrap img {
width: 100%; max-height: 260px;
object-fit: contain;
display: block;
}
.modal-img-placeholder {
display: flex; flex-direction: column; align-items: center; gap: 10px;
color: var(–muted); font-size: 13px; padding: 40px 20px;
text-align: center;
}
.modal-img-placeholder span { font-size: 48px; }

.modal-content { padding: 20px 20px 24px; }

.modal-exo-name {
font-family: ‘Bebas Neue’, sans-serif;
font-size: 30px; color: #fff; letter-spacing: 1px;
line-height: 1; margin-bottom: 4px;
}
.modal-series {
font-size: 12px; color: var(–accent);
font-weight: 700; letter-spacing: 2px; text-transform: uppercase;
margin-bottom: 16px;
}

.modal-section-title {
font-family: ‘Barlow Condensed’, sans-serif;
font-size: 13px; font-weight: 700; letter-spacing: 3px;
text-transform: uppercase; color: var(–accent2);
margin-bottom: 10px; margin-top: 18px;
}

.muscles-list { display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 4px; }
.muscle-tag {
font-size: 11px; font-weight: 600; letter-spacing: 1px; text-transform: uppercase;
padding: 3px 10px; border-radius: 20px;
background: rgba(255,77,0,0.12); color: var(–accent);
border: 1px solid rgba(255,77,0,0.2);
}
.muscle-tag.secondary { background: rgba(68,138,255,0.1); color: var(–blue); border-color: rgba(68,138,255,0.2); }

.steps-list { list-style: none; display: flex; flex-direction: column; gap: 8px; }
.step { display: flex; gap: 12px; align-items: flex-start; }
.step-num {
flex-shrink: 0;
width: 22px; height: 22px; border-radius: 50%;
background: var(–accent); color: #fff;
font-size: 11px; font-weight: 700;
display: flex; align-items: center; justify-content: center;
margin-top: 1px;
}
.step p { font-size: 13px; color: var(–text); line-height: 1.6; font-weight: 300; }

.tip-box {
background: rgba(255,170,0,0.07);
border-left: 3px solid var(–accent2);
border-radius: 0 6px 6px 0;
padding: 10px 14px;
margin-top: 16px;
}
.tip-box p { font-size: 12px; color: var(–muted); line-height: 1.6; }
.tip-box strong { color: var(–accent2); }

/* TIPS */
.tips-section { background: var(–dark); border: 1px solid var(–border); border-radius: 10px; padding: 30px; margin-top: 10px; }
.tips-title { font-family: ‘Bebas Neue’, sans-serif; font-size: 32px; color: var(–accent); margin-bottom: 20px; letter-spacing: 2px; }
.tips-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 16px; }
.tip-card { padding: 16px; background: var(–card); border-radius: 6px; border-left: 3px solid var(–accent); }
.tip-card h4 { font-family: ‘Barlow Condensed’, sans-serif; font-size: 14px; font-weight: 700; letter-spacing: 1px; text-transform: uppercase; color: var(–accent2); margin-bottom: 6px; }
.tip-card p { font-size: 12px; color: var(–muted); line-height: 1.6; font-weight: 300; }

.prog-banner { background: linear-gradient(135deg, rgba(255,77,0,0.12), rgba(255,170,0,0.08)); border: 1px solid rgba(255,77,0,0.3); border-radius: 8px; padding: 20px 24px; margin-top: 40px; display: flex; align-items: center; gap: 16px; }
.prog-icon { font-size: 28px; }
.prog-text h4 { font-family: ‘Barlow Condensed’, sans-serif; font-size: 16px; font-weight: 700; letter-spacing: 1px; text-transform: uppercase; color: var(–accent); margin-bottom: 4px; }
.prog-text p { font-size: 13px; color: var(–muted); line-height: 1.6; }

@media (max-width: 600px) {
.hero { padding: 40px 20px 36px; }
.legend { padding: 16px 20px; }
.semaine-dates { margin-left: 0; }
.modal { max-width: 95vw; }
}

@supports (padding: max(0px)) {
.hero { padding-bottom: calc(50px + max(0px, env(safe-area-inset-bottom))); }
.container { padding-bottom: calc(50px + max(0px, env(safe-area-inset-bottom))); }
}
</style>

</head>
