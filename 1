  function openModal(id, series) {
    const data = EXO_DATA[id];
    if (!data) return;

    document.getElementById('modalName').textContent = data.name;
    document.getElementById('modalSeries').textContent = series || '';

    const mw = document.getElementById('modalMuscles');
    mw.innerHTML = data.muscles.map(m => `<span class="muscle-tag">${m}</span>`).join('') +
      (data.secondary || []).map(m => `<span class="muscle-tag secondary">${m}</span>`).join('');

    const sw = document.getElementById('modalSteps');
    sw.innerHTML = data.steps.map((s, i) => `<li class="step"><span class="step-num">${i+1}</span><p>${s}</p></li>`).join('');

    document.getElementById('modalTip').innerHTML = `<p>${data.tip}</p>`;

    const iw = document.getElementById('modalImgWrap');
    iw.innerHTML = `<div class="modal-img-placeholder"><span>⏳</span><p>Chargement...</p></div>`;
    const img = new Image();
    img.onload = () => { iw.innerHTML = ''; iw.appendChild(img); };
    img.onerror = () => { iw.innerHTML = `<div class="modal-img-placeholder"><span>💪</span><p>Image non disponible<br><small style="font-size:10px;margin-top:4px;display:block">Cherche "${data.name}" sur YouTube pour voir la vidéo</small></p></div>`; };
    img.src = data.img;
    img.alt = data.name;
    img.style.cssText = 'width:100%;max-height:260px;object-fit:contain;display:block;';

    document.getElementById('modalOverlay').classList.add('active');
    document.body.style.overflow = 'hidden';
  }

  function closeModal() {
    document.getElementById('modalOverlay').classList.remove('active');
    document.body.style.overflow = '';
  }

  function closeModalOutside(e) {
    if (e.target === document.getElementById('modalOverlay')) closeModal();
  }

  document.addEventListener('keydown', e => { if (e.key === 'Escape') closeModal(); });

  // Service Worker pour PWA
  if ('serviceWorker' in navigator) {
    navigator.serviceWorker.register('data:application/javascript,self.addEventListener("install",e=>self.skipWaiting());self.addEventListener("activate",e=>e.waitUntil(clients.claim()));');
  }
</script>

